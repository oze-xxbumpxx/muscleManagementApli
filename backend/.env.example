# ローカル開発: リポジトリ直下で `docker-compose up -d` した Postgres に接続
DB_HOST=localhost
DB_PORT=5432
DB_NAME=muscle_management
DB_USER=muscle_user
DB_PASSWORD=muscle_password

# テスト用（docker-compose の postgres-test / ポート 5433）を使う場合の例
# DB_PORT=5433
# DB_NAME=muscle_management_test
# DB_USER=test_user
# DB_PASSWORD=test_password
